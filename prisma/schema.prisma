// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  //output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Omzet {
  id        Int      @id @default(autoincrement())
  nominal   Float
  tanggal   DateTime @default(now())
  metode    String
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model PageVisit {
  id        Int      @id @default(autoincrement())
  path      String   @default("/")
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model GrowthMetric {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordedAt      DateTime @unique @map("recorded_at") @db.Date
  igFollowers     Int?     @map("ig_followers")
  igViews         Int?     @map("ig_views")
  igPosts         Int?     @map("ig_posts")
  igLikes         Int?     @map("ig_likes")
  tiktokFollowers Int?     @map("tiktok_followers")
  tiktokViews     Int?     @map("tiktok_views")
  tiktokPosts     Int?     @map("tiktok_posts")
  tiktokLikes     Int?     @map("tiktok_likes")
  totalCustomers  Int?     @map("total_customers")
  websiteVisitors Int?     @map("website_visitors")
  websiteViews    Int?     @map("website_views")
  activeOrders    Int?     @map("active_orders")
  testimonials    Int?     @map("testimonials")
  totalRevenue    BigInt?  @map("total_revenue")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("growth_metrics")
}